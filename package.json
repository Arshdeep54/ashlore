{
  "name": "ashlore",
  "version": "0.1.0",
  "private": true,
  "description": "Personal knowledge graph for developers — ingest AI chats, commits, and work history into a queryable second brain.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "ingest": "tsx src/cli/ingest.ts",
    "ingest:all": "tsx src/cli/ingest.ts --source all",
    "ingest:dry": "tsx src/cli/ingest.ts --source all --dry-run",
    "db:migrate": "tsx src/cli/migrate.ts",
    "enrich": "tsx src/cli/enrich.ts",
    "export": "tsx src/cli/export.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/google": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@google/generative-ai": "^0.21.0",
    "adm-zip": "^0.6.0",
    "ai": "^4.0.0",
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "date-fns": "^4.0.0",
    "drizzle-orm": "^0.45.2",
    "geist": "^1.7.2",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "5.8.2"
  }
}
